# =============================================================================
# BlueprintGPT Environment Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Backend Selection (NEW - IMPORTANT!)
# -----------------------------------------------------------------------------
# Options: "auto", "planner", "planner_direct", "learned", "algorithmic", "hybrid"
# Recommended: keep "auto" and control the core residential rollout with
# BLUEPRINT_AUTO_CORE_BACKEND below.
# "planner_direct" uses the trained model output directly without algorithmic packing
BLUEPRINT_BACKEND_MODE=auto

# Core residential routing policy while BLUEPRINT_BACKEND_MODE=auto
# Options: "algorithmic", "planner", "planner_direct", "planner_if_available", "planner_direct_if_available"
# Recommended: "algorithmic" until planner benchmark and rollout checks pass
BLUEPRINT_AUTO_CORE_BACKEND=algorithmic
BLUEPRINT_HOST=127.0.0.1
BLUEPRINT_PORT=8010

# -----------------------------------------------------------------------------
# AI Model Configuration
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_ENABLED=true

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
BLUEPRINT_LOG_LEVEL=INFO
BLUEPRINT_DIRECT_PRINT=true
BLUEPRINT_DETAILED_LOGGING=false
BLUEPRINT_DEV_RELOAD=false

# -----------------------------------------------------------------------------
# Model Checkpoint
# -----------------------------------------------------------------------------
BLUEPRINTGPT_CHECKPOINT=learned/model/checkpoints/improved_v1.pt
BLUEPRINTGPT_PLANNER_CHECKPOINT=learned/planner/checkpoints/room_planner.pt

# -----------------------------------------------------------------------------
# Model Cache Configuration
# -----------------------------------------------------------------------------
MODEL_CACHE_ENABLED=true
MODEL_CACHE_MAX_SIZE=5
MODEL_CACHE_TTL_SECONDS=3600

# -----------------------------------------------------------------------------
# Template System
# -----------------------------------------------------------------------------
LAYOUT_USE_TEMPLATES=false

# -----------------------------------------------------------------------------
# Feature Flags - Centroid Collapse Prevention
# -----------------------------------------------------------------------------
LEARNED_JITTER_ENABLED=true
LEARNED_JITTER_SIGMA=0.02
ADAPTIVE_JITTER_ENABLED=true
MAX_ADAPTIVE_JITTER_MULTIPLIER=3.0
DIRECTIONAL_JITTER_ENABLED=true
LEARNED_OVERLAP_FILTER_ENABLED=true
OVERLAP_DROP_FRAC=0.5
MAX_RESAMPLE_ON_OVERLAP=3

# -----------------------------------------------------------------------------
# Feature Flags - Overlap Processing
# -----------------------------------------------------------------------------
LEARNED_OVERLAP_PROCESSOR_ENABLED=false
OVERLAP_PROCESSOR_IOU_THRESH=0.12
OVERLAP_PROCESSOR_IOU_THRESH_X2=0.30
OVERLAP_PROCESSOR_CHECK_X2=true
LEARNED_MINDIM_PROCESSOR_ENABLED=false

# -----------------------------------------------------------------------------
# Feature Flags - Repair & Optimization
# -----------------------------------------------------------------------------
REPAIR_FORCE_PUSH_ENABLED=false
REPAIR_FORCE_PUSH_STEP=0.05
REPAIR_FORCE_PUSH_DAMPING=0.95
REPAIR_FORCE_PUSH_MAX_ITERS=100
REPAIR_FORCE_PUSH_MIN_OV=0.01

BOX_OPT_ENABLED=false
BOX_OPT_TIME_LIMIT=10
BOX_OPT_MIN_GAP=0.5
BOX_OPT_GRID_SCALE=0.1

# -----------------------------------------------------------------------------
# Quality Monitoring
# -----------------------------------------------------------------------------
QUALITY_DASHBOARD_DB=quality_metrics.db
QUALITY_WINDOW_SIZE=100
QUALITY_ALERT_THRESHOLD=0.4

# -----------------------------------------------------------------------------
# Performance Optimization
# -----------------------------------------------------------------------------
PRERANK_USE_SPATIAL_INDEX=true
PRERANK_INDEX_THRESHOLD=20

# -----------------------------------------------------------------------------
# Collapse Detection Thresholds
# -----------------------------------------------------------------------------
COLLAPSE_MIN_ROOMS=3
COLLAPSE_MEDIAN_DIST_THRESHOLD=2.0
COLLAPSE_IOU_PAIR_RATIO_THRESHOLD=0.4
IOU_BAD_THRESH=0.3
BOUNDARY_MARGIN=0.5
