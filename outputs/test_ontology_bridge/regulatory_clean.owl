         xmlns="http://genai.local/regulatory.owl#"
         xmlns:swrl="http://www.w3.org/2003/11/swrl#">

<owl:Ontology rdf:about="http://genai.local/regulatory.owl"/>

<owl:ObjectProperty rdf:about="#containsRoom">
  <rdfs:domain rdf:resource="#Building"/>
  <rdfs:range rdf:resource="#Room"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasCorridor">
  <rdfs:domain rdf:resource="#Building"/>
  <rdfs:range rdf:resource="#Corridor"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasDoor">
  <rdfs:domain rdf:resource="#Room"/>
  <rdfs:range rdf:resource="#Door"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#connects">
  <rdfs:domain rdf:resource="#Door"/>
  <rdfs:range rdf:resource="#Room"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasExit">
  <rdfs:domain rdf:resource="#Building"/>
  <rdfs:range rdf:resource="#Exit"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasViolation">
  <rdfs:domain rdf:resource="#Building"/>
  <rdfs:range rdf:resource="#Violation"/>
</owl:ObjectProperty>

<owl:DatatypeProperty rdf:about="#hasArea">
  <rdfs:domain rdf:resource="#Room"/>
