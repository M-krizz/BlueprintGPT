<owl:NamedIndividual rdf:about="#Rule_MinArea_NonCompliant">
  <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Imp"/>
  <swrl:body>
    <rdf:Description>
      <rdf:first>
        <swrl:ClassAtom>
          <swrl:classPredicate rdf:resource="#Room"/>
          <swrl:argument1 rdf:resource="urn:swrl#r"/>
        </swrl:ClassAtom>
      </rdf:first>
      <rdf:rest>
        <rdf:Description>
          <rdf:first>
            <swrl:DatavaluedPropertyAtom>
              <swrl:propertyPredicate rdf:resource="#hasArea"/>
              <swrl:argument1 rdf:resource="urn:swrl#r"/>
              <swrl:argument2 rdf:resource="urn:swrl#a"/>
            </swrl:DatavaluedPropertyAtom>
          </rdf:first>
          <rdf:rest>
            <rdf:Description>
              <rdf:first>
                <swrl:DatavaluedPropertyAtom>
                  <swrl:propertyPredicate rdf:resource="#hasMinRequiredArea"/>
                  <swrl:argument1 rdf:resource="urn:swrl#r"/>
                  <swrl:argument2 rdf:resource="urn:swrl#m"/>
                </swrl:DatavaluedPropertyAtom>
              </rdf:first>
              <rdf:rest>
                <rdf:Description>
                  <rdf:first>
                    <swrl:BuiltinAtom>
                      <swrl:builtin rdf:resource="http://www.w3.org/2003/11/swrlb#lessThan"/>
                      <swrl:arguments>
                        <rdf:Description>
                          <rdf:first rdf:resource="urn:swrl#a"/>
                          <rdf:rest>
                            <rdf:Description>
                              <rdf:first rdf:resource="urn:swrl#m"/>
                              <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                            </rdf:Description>
                          </rdf:rest>
                        </rdf:Description>
                      </swrl:arguments>
                    </swrl:BuiltinAtom>
                  </rdf:first>
                  <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                </rdf:Description>
              </rdf:rest>
            </rdf:Description>
          </rdf:rest>
        </rdf:Description>
      </rdf:rest>
    </rdf:Description>
  </swrl:body>
  <swrl:head>
    <rdf:Description>
      <rdf:first>
        <swrl:ClassAtom>
          <swrl:classPredicate rdf:resource="#AreaNonCompliantRoom"/>
          <swrl:argument1 rdf:resource="urn:swrl#r"/>
        </swrl:ClassAtom>
      </rdf:first>
      <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    </rdf:Description>
  </swrl:head>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Rule_TravelDistance_NonCompliant">
  <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Imp"/>
  <swrl:body>
    <rdf:Description>
      <rdf:first>
        <swrl:ClassAtom>
