# BlueprintGPT Environment Configuration
# Copy this file to .env and fill in your values

# Gemini API Configuration
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_ENABLED=false

# Backend Selection
BLUEPRINT_BACKEND_MODE=auto
BLUEPRINT_AUTO_CORE_BACKEND=algorithmic
BLUEPRINT_HOST=127.0.0.1
BLUEPRINT_PORT=8010

# Model Checkpoints
BLUEPRINTGPT_PLANNER_CHECKPOINT=learned/planner/checkpoints/room_planner.pt

# Feature Flags
MODEL_CACHE_ENABLED=true
LAYOUT_USE_TEMPLATES=true
BLUEPRINT_DEV_RELOAD=false
